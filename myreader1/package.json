{
  "name": "Myreader",
  "version": "1.0.0",
  "description": "PDF reader ",
  "homepage": "https://github.com/sentflix01/Myreader#readme",
  "bugs": {
    "url": "https://github.com/sentflix01/Myreader/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentflix01/Myreader.git"
  },
  "license": "ISC",
  "author": "Sintayehu.M",
  "scripts": {
    "start": "node server.js",
    "start:dev": "nodemon server.js",
    "start:prod": "cross-env NODE_ENV=production nodemon server.js",
    "debug": "node --inspect server.js",
    "clean": "rimraf public/dist",
    "watch:js": "env-cmd -f config.env npx parcel watch client/src/index.js --dist-dir public/dist/js --no-content-hash",
    "build:js": "env-cmd -f config.env npx parcel build client/src/index.js --dist-dir public/dist/js --no-content-hash",
    "dev:frontend": "env-cmd -f config.env npx parcel index.html",
    "test": "jest",
    "validate": "node validate-fixes.js",
    "check-env": "node check-env.js",
    "test-fixes": "node test-fixes.js",
    "test-rag": "node test-rag-system.js",
    "test-rag-api": "node test-rag-api.js",
    "validate-rag": "node validate-rag.js",
    "test-stripe": "node test-stripe-subscription.js",
    "test-subscription-flow": "node test-subscription-flow.js",
    "debug-auth": "node debug-auth.js",
    "health-check": "node utils/databaseHealthChecker.js",
    "monitor-db": "node utils/databaseHealthChecker.js --monitor",
    "fix-deps": "npm install && npm audit fix && npm cache clean --force"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-xss-sanitizer": "^2.0.2",
    "helmet": "^8.1.0",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "mongodb": "6.10.0",
    "mongoose": "8.8.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "pug": "^3.0.4",
    "puppeteer": "^21.6.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.8",
    "stripe": "^17.3.1",
    "supertest": "^6.3.4",
    "uuid": "^10.0.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@prettier/plugin-pug": "^3.4.2",
    "@types/jsonwebtoken": "^9.0.10",
    "buffer": "^6.0.3",
    "cross-env": "^10.1.0",
    "crypto-browserify": "^3.12.1",
    "env-cmd": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "events": "^3.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "os-browserify": "^0.3.0",
    "parcel": "^2.16.4",
    "path-browserify": "^1.0.1",
    "prettier": "^3.8.1",
    "process": "^0.11.10",
    "rimraf": "^6.1.3",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "vm-browserify": "^1.1.2"
  }
}
