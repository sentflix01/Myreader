header.header
  a(href="/")
    img.logo(src="img/logos/sentreader remover.png" alt="MyReader logo")
  nav.main-nav
    video.hero-bg-video(src="img/video 7.mp4" autoplay muted loop playsinline)
    ul.main-nav-list
      li
        a.main-nav-link(href="/chat") #{t('nav.chat')}
      li
        a.main-nav-link(href="/dashboard") #{t('nav.dashboard')}
      li
        a.main-nav-link(href="/pricing") #{t('nav.pricing')}
      li
        a.main-nav-link(href="/services") #{t('nav.services')}
      li
        a.main-nav-link(href="/features") #{t('nav.features')}
      li.main-nav-utility
        select#languageSelect.nav-util-btn(aria-label="Language")
          option(value="en" selected=language === 'en') EN
          option(value="am" selected=language === 'am') አማ
        button#themeToggle.nav-util-btn(type="button" aria-label="Toggle theme")
          i.fas.fa-sun.theme-icon-sun
          i.fas.fa-moon.theme-icon-moon
        button#tourToggle.nav-util-btn(type="button")
          i.fas.fa-route
          span #{t('nav.tour')}
      if user
        li
          .profile-toggle-container
            button#profileToggle.profile-toggle-btn
              .user-avatar-small= user.name.split(' ').map(n => n[0]).join('').toUpperCase()
              span.user-name-small= user.name.split(' ')[0]
              i.fas.fa-chevron-down.toggle-arrow
            #profileDropdown.profile-dropdown
              .profile-content
                .profile-header
                  .profile-avatar-large= user.name.split(' ').map(word => word[0]).join('').toUpperCase()
                  .profile-content-name
                    .profile-name= user.name
                    .profile-email= user.email
              .profile-status
                if user.subscriptionTier === 'free'
                  span.status-badge.status-free
                    i.fas.fa-seedling.profile-status__icon
                    |  Free plan
                else if user.subscriptionTier === 'premium'
                  span.status-badge.status-premium
                    i.fas.fa-crown.profile-status__icon
                    |  Premium
                else if user.subscriptionTier === 'enterprise'
                  span.status-badge.status-enterprise
                    i.fas.fa-building.profile-status__icon
                    |  Enterprise
                if user.subscriptionStatus
                  - const prettyStatus = user.subscriptionStatus.charAt(0).toUpperCase() + user.subscriptionStatus.slice(1);
                  span.status-badge(class=`status-${user.subscriptionStatus}`)
                    i.fas.fa-circle.profile-status__icon
                    |  #{prettyStatus}
              .profile-actions
                a#editProfile.action-item(href='/editProfile')
                  .action-icon
                    i.fas.fa-user-edit
                  span.action-text #{t('nav.accountSettings')}
                a#contact.action-item(href='/#contacts')
                  .action-icon
                    i.fas.fa-headset
                  span.action-text #{t('nav.support')}
                a#logout.action-item(href='/logout')
                  .action-icon
                    i.fas.fa-sign-out-alt
                  span.action-text #{t('nav.logout')}
      else
        li
          a.main-nav-link(href="/login") #{t('nav.login')}
        li
          a.main-nav-link(href="/signup") #{t('nav.signup')}
#dropdownOverlay.dropdown-overlay
button.btn-mobile-nav
  ion-icon.icon-mobile-nav(name="menu-outline")
  ion-icon.icon-mobile-nav(name="close-outline")

