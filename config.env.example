# Copy this to config.env and fill in your values
DATABASE=mongodb+srv://username:<PASSWORD>@cluster.mongodb.net/myreader?retryWrites=true&w=majority
DATABASE_PASSWORD=yourpassword

# JWT (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_64_char_secret_here
JWT_EXPIRES_IN=90d

PORT=3000
NODE_ENV=development

# Stripe (dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PREMIUM=price_premium_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly_id
STRIPE_WEBHOOK_SECRET=whsec_...

# Gemini (aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...
EMBEDDING_URL=https://generativelanguage.googleapis.com/v1beta/models/text-embedding-004:embedContent
API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash-latest:generateContent

# Pinecone (optional)
PINECONE_ENABLED=true
PINECONE_API_KEY=...
PINECONE_ENV=us-east1-gcp
PINECONE_INDEX=myreader-index

CORS_ORIGINS=http://localhost:3000

# Email (optional - app passwords)
NODE_MAILER_EMAIL=noreply@sentreader.com
NODE_MAILER_PASSWORD=abcd efgh ijkl mnop

