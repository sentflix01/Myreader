extends base

block content
    section#services.section-meals
      .container
        h2.heading-secondary
          = t('services.title')
      .container.grid.grid--3-cols.margin-bottom-md
        .meal
          video.meal-img(src='img/meals/video 2.mp4' autoplay='' muted='' loop='' playsinline='')
          .meal-content
            .meal-tags
              span.tag.tag--vegetarian ChatPDF
            p.meal-title
            ul.meal-attributes
              li.meal-attribute
                ion-icon.meal-icon(name='star-outline')
                span
                  strong 4.9
        .meal
          video.meal-img(src='img/meals/video 1.mp4' autoplay='' muted='' loop='' playsinline='')
          .meal-content
            .meal-tags
              span.tag.tag--vegan AI generation
            p.meal-title
            ul.meal-attributes
              li.meal-attribute
                ion-icon.meal-icon(name='star-outline')
                span
                  strong 4.8
                  |  #{t('services.ratingLabel')} (441)
        .diets
          h3.heading-tertiary= t('services.formats.title')
          ul.list
            li.list-item
              ion-icon.list-icon(name='checkmark-outline')
              span PDF
            li.list-item
              ion-icon.list-icon(name='checkmark-outline')
              span WORD
            li.list-item
              ion-icon.list-icon(name='checkmark-outline')
              span WEB
            li.list-item
              ion-icon.list-icon(name='checkmark-outline')
              span PPT
            li.list-item
              ion-icon.list-icon(name='checkmark-outline')
              span EXCEL
            li.list-item
              ion-icon.list-icon(name='checkmark-outline')
              span IMAGE
            li.list-item
              ion-icon.list-icon(name='checkmark-outline')
              span SCREENSHOT

    section#dashboard.section-testimonials
      .testimonials-container
        h2.heading-secondary= t('services.reviews.title')

        if reviews && reviews.length
          .testimonials
            each review in reviews
              figure.testimonial
                - const userName = review.user ? review.user.name : 'customer';
                - const userPhoto = review.user && review.user.photo ? review.user.photo : 'default.jpg';
                img.testimonial-img(
                  alt=`Photo of ${userName}`,
                  src=`/img/users/${userPhoto}`
                )
                blockquote.testimonial-text
                  | &ldquo;#{review.review}&rdquo;
                p.testimonial-name &mdash; #{review.user ? review.user.name : 'Anonymous'}
                .reviews__rating
                  each star in [1, 2, 3, 4, 5]
                    svg.reviews__star(
                      class=`reviews__star--${review.rating >= star ? 'active' : 'inactive'}`
                    )
                      use(xlink:href='/img/icons.svg#icon-star')
        else
          p.testimonial-text= t('services.noReviews')

      .gallery
        figure.gallery-item
          img(src='img/gallery/gallery-1.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-2.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-3.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-4.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-5.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-6.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-7.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-8.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-9.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-10.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-11.jpg' alt=t('services.galleryAlt'))
        figure.gallery-item
          img(src='img/gallery/gallery-12.jpg' alt=t('services.galleryAlt'))
