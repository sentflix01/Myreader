  .chat-body
    .message.bot-message
      svg.bot-avatar(width='50' height='50' viewbox='0 0 1024 1024')
        path(d='M738.3 287.6H285.7c-59 0-106.8 47.8-106.8 106.8v303.1c0 59 47.8 106.8 106.8 106.8h81.5v111.1c0 .7.8 1.1 1.4.7l166.9-110.6 41.8-.8h117.4l43.6-.4c59 0 106.8-47.8 106.8-106.8V394.5c0-59-47.8-106.9-106.8-106.9zM351.7 448.2c0-29.5 23.9-53.5 53.5-53.5s53.5 23.9 53.5 53.5-23.9 53.5-53.5 53.5-53.5-23.9-53.5-53.5zm157.9 267.1c-67.8 0-123.8-47.5-132.3-109h264.6c-8.6 61.5-64.5 109-132.3 109zm110-213.7c-29.5 0-53.5-23.9-53.5-53.5s23.9-53.5 53.5-53.5 53.5 23.9 53.5 53.5-23.9 53.5-53.5 53.5zM867.2 644.5V453.1h26.5c19.4 0 35.1 15.7 35.1 35.1v121.1c0 19.4-15.7 35.1-35.1 35.1h-26.5zM95.2 609.4V488.2c0-19.4 15.7-35.1 35.1-35.1h26.5v191.3h-26.5c-19.4 0-35.1-15.7-35.1-35.1zM561.5 149.6c0 23.4-15.6 43.3-36.9 49.7v44.9h-30v-44.9c-21.4-6.5-36.9-26.3-36.9-49.7 0-28.6 23.3-51.9 51.9-51.9s51.9 23.3 51.9 51.9z')
      .message-text
        | Hey there &#x1F590;&#xFE0F; 
        br
        | How can I help you today?
  // chatbot footer
  .chat-footer
    form.chat-form(action='#')
      textarea.message-input(placeholder='message...' required='')
      .chat-controls
        button#emoji-picker.material-symbols-outlined(type='button')
          svg(width='24' height='24' viewBox='0 0 24 24' fill='currentColor')
            path(d='M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-4c-1.48 0-2.75-.81-3.45-2H6.88c.8 2.05 2.79 4 5.12 4s4.32-1.95 5.12-4h-1.67c-.7 1.19-1.97 2-3.45 2z')
            circle(cx='9' cy='11' r='1.5')
            circle(cx='15' cy='11' r='1.5')
        .file-upload-wrapper
          input#file-input(type='file' accept='images/*' hidden='')
          img(src='')
          button#file-upload.material-symbols-rounded(type='button')
            svg(width='24' height='24' viewBox='0 0 24 24' fill='currentColor')
              path(d='M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z')
          button#file-cancel.material-symbols-rounded(type='button')
            svg(width='24' height='24' viewBox='0 0 24 24' fill='currentColor')
              path(d='M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z')
        button#send-message.material-symbols-rounded(type='submit')
          svg(width='24' height='24' viewBox='0 0 24 24' fill='currentColor')
            path(d='M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8-8 8z')
