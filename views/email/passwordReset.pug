extends baseEmail

block content
  p Hi #{firstName},
  p Forgot your password? Use the link below to choose a new password on our site.
  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation', border='0', cellpadding='0', cellspacing='0')
            tbody
              tr
                td
                  a(href=`${url}`, target='_blank') Reset your password
  p if you didn't forget password, please ignore this email!