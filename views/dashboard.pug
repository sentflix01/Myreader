extends base

block content
  main.main
    section.section-dashboard
      .dashboard-header
        .dashboard-user
          if user
            img.dashboard-user__photo(src=`/img/users/${user.photo}` alt=`${user.name}`)
            .dashboard-user__info
              p.dashboard-user__welcome Welcome back,
              h2.heading-secondary.dashboard-user__name #{user.name}
          else
            h2.heading-secondary Your dashboard
            p.text-muted Sign in to see your recent activity.

        .dashboard-summary
          .dashboard-card
            p.dashboard-card__label Total reviews
            h3.dashboard-card__value #{reviews && reviews.length ? reviews.length : 0}
          .dashboard-card
            p.dashboard-card__label Average rating
            if reviews && reviews.length
              - const avgRating = (reviews.reduce((sum, r) => sum + (r.rating || 0), 0) / reviews.length).toFixed(1);
              h3.dashboard-card__value #{avgRating}
            else
              h3.dashboard-card__value -
          .dashboard-card
            p.dashboard-card__label Documents reviewed
            if reviews && reviews.length
              - const docCount = reviews.reduce((acc, r) => (r.document ? acc + 1 : acc), 0);
              h3.dashboard-card__value #{docCount}
            else
              h3.dashboard-card__value 0

      if user
        .dashboard-user-chart
          h4.dashboard-chart__title Your activity overview
          canvas#userStatsChart(width='360' height='140')

    section.section-dashboard-list
      .dashboard-list__header
        h3.heading-tertiary Recent reviews
        if reviews && reviews.length
          p.text-muted Showing #{reviews.length} latest reviews
        else
          p.text-muted No reviews yet. Once you start using SentReader, your recent activity will appear here.

      if reviews && reviews.length
        .dashboard-table-wrapper
          table.dashboard-table
            thead
              tr
                th User
                th Document
                th Chat
                th Rating
                th Date
            tbody
              each review in reviews
                tr
                  td
                    if review.user
                      span #{review.user.name}
                    else
                      span —
                  td
                    if review.document
                      span #{review.document.originalFileName}
                    else
                      span —
                  td
                    if review.chat
                      span #{review.chat.title}
                    else
                      span —
                  td
                    span #{review.rating || '-'}
                  td
                    span #{review.createdAt ? review.createdAt.toDateString ? review.createdAt.toDateString() : review.createdAt : '-'}

    // Admin-only analytics (numbers only, no inline JS)
    if user && user.role === 'admin'
      section.section-dashboard-admin
        .dashboard-list__header
          h3.heading-tertiary Admin analytics
        .dashboard-header
          .dashboard-summary
            .dashboard-card
              p.dashboard-card__label Total documents
              h3.dashboard-card__value #{typeof totalDocuments !== 'undefined' ? totalDocuments : 0}
            .dashboard-card
              p.dashboard-card__label Documents by type
              if documentsByType && documentsByType.length
                ul.dashboard-mini-list
                  each stat in documentsByType
                    li
                      span #{stat._id}: 
                      strong #{stat.count}
              else
                p.text-muted No documents uploaded yet.
            .dashboard-card
              p.dashboard-card__label Users by tier
              ul.dashboard-mini-list
                li
                  span Free: 
                  strong #{usersByTier && usersByTier.free ? usersByTier.free : 0}
                li
                  span Starter: 
                  strong #{usersByTier && usersByTier.premium ? usersByTier.premium : 0}
                li
                  span Enterprise: 
                  strong #{usersByTier && usersByTier.enterprise ? usersByTier.enterprise : 0}